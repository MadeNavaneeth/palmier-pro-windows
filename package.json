{
  "name": "palmier-pro-windows",
  "version": "0.1.0",
  "description": "Palmier Pro for Windows — AI-native video editor. A GPL-3.0 derivative of Palmier Pro (macOS) by Palmier, Inc.",
  "author": "Palmier Pro Windows Contributors",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc && vite build && electron-builder",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:rust": "cd native && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "clean": "rimraf dist out",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "electron-log": "^5.4.4",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.9",
    "fluent-ffmpeg": "^2.1.3",
    "nanoid": "^5.1.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.36",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@napi-rs/cli": "^3.0.0-alpha.86",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9.28.0",
    "postcss": "^8.5.4",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "io.palmier.pro.windows",
    "productName": "Palmier Pro",
    "directories": {
      "output": "out"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "Palmier Pro Windows Contributors"
    },
    "files": [
      "dist/**/*",
      "native/*.node"
    ],
    "extraResources": [
      {
        "from": "native/",
        "to": "native/",
        "filter": [
          "*.node"
        ]
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "license": "LICENSE"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}
